# ─── BASE DE DATOS ───────────────────────────────────
# PostgreSQL para datos clínicos
DATABASE_URL=postgresql://lumajira:password@localhost:5432/lumajira_db

# TimescaleDB para telemetría del hardware (puede ser la misma instancia con extensión)
TIMESCALE_URL=postgresql://lumajira:password@localhost:5432/lumajira_telemetry

# Redis para pub/sub en tiempo real
REDIS_URL=redis://localhost:6379/0

# ─── IA ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── HARDWARE / MQTT ─────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=lumajira_broker
MQTT_PASSWORD=secret

# ─── AUTH ────────────────────────────────────────────
JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRE_HOURS=24

# ─── APP ─────────────────────────────────────────────
ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
